{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=BookNowDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Secret": "THIS_SHOULD_BE_A_VERY_LONG_AND_SECURE_SECRET_KEY_32_CHARS_MIN",
    "Issuer": "BookNow.Api",
    "Audience": "BookNow.Client",
    "ExpiryMinutes": 60
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },
  "Swagger": {
    "Title": "BookNow API",
    "Version": "v1",
    "Description": "Mechanic Workshop Booking & Discovery Platform API"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 2
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "AllowedHosts": "*"
}